@startuml
skinparam linetype ortho
skinparam backgroundColor #1E1E1E
skinparam defaultTextAlignment center
skinparam ArrowColor #B0C4DE
skinparam shadowing false
skinparam FontColor #FFFFFF
skinparam classFontColor #FFFFFF
skinparam classAttributeFontColor #FFFFFF
skinparam classMethodFontColor #FFFFFF

skinparam class {
  BackgroundColor #2D2D2D
  BorderColor #8A8A8A
  FontColor #E0E0E0
}

!include CustomerServiceV1.puml
!include CustomerToCustomerProfileResponseBodyMapper.puml
!include CustomerToCustomerDetailsResponseBodyMapper.puml

class CustomerRestControllerV1 {
    - CustomerServiceV1 service
    - CustomerToCustomerProfileResponseBodyMapper customerToCustomerProfileMapper
    - CustomerToCustomerDetailsResponseBodyMapper customerToCustomerDetailsMapper

    + ResponseEntity<Void> createCustomer(CreateCustomerRequestBody requestBody)
    + ResponseEntity<CustomerDetailsResponseBody> getCustomerDetails(Authentication authentication)
    + ResponseEntity<byte[]> getCustomerImage(String username)
    + ResponseEntity<PageResponse<CustomerProfileResponseBody>> searchCustomers(String query, Pageable pageable)
    + ResponseEntity<Void> updateCustomerDetails(Authentication authentication, UpdateCustomerDetailsRequestBody requestBody)
    + ResponseEntity<Void> updateCustomerPassword(Authentication authentication, UpdateCustomerPasswordRequestBody)
    + ResponseEntity<Void> updateCustomerImage((Authentication authentication, MultipartFile image)
    + ResponseEntity<Void> restoreDefaultImage(Authentication authentication)
    + ResponseEntity<Void> deleteCustomer(Authentication authentication)
}

CustomerRestControllerV1 --> CustomerServiceV1
CustomerRestControllerV1 --> CustomerToCustomerProfileResponseBodyMapper
CustomerRestControllerV1 --> CustomerToCustomerDetailsResponseBodyMapper
@enduml