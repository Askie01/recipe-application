@startuml
skinparam linetype ortho
skinparam backgroundColor #1E1E1E
skinparam defaultTextAlignment center
skinparam ArrowColor #B0C4DE
skinparam shadowing false
skinparam FontColor #FFFFFF
skinparam classFontColor #FFFFFF
skinparam classAttributeFontColor #FFFFFF
skinparam classMethodFontColor #FFFFFF

skinparam class {
  BackgroundColor #2D2D2D
  BorderColor #8A8A8A
  FontColor #E0E0E0
}

!include Mapper.puml
!include ToDTOMapper.puml
!include RecipeRepositoryV3.puml

interface RecipeToSearchRecipeResponseBodyMapper extends Mapper, ToDTOMapper {
    + void map(Recipe source, SearchRecipeResponseBody target)
    + SearchRecipeResponseBody mapToDTO(Recipe recipe)
}

class DefaultRecipeToSearchRecipeResponseBodyMapper implements RecipeToSearchRecipeResponseBodyMapper {
    - RecipeRepositoryV3 repository

    + SearchRecipeResponseBody mapToDTO(Recipe recipe)
    + void map(Recipe recipe, SearchRecipeResponseBody searchRecipeResponseBody)
    - void mapOwner(Recipe recipe, SearchRecipeResponseBody searchRecipeResponseBody)
    - void mapId(Recipe recipe, SearchRecipeResponseBody searchRecipeResponseBody)
    - void mapName(Recipe recipe, SearchRecipeResponseBody searchRecipeResponseBody)
    - void mapDescription(Recipe recipe, SearchRecipeResponseBody searchRecipeResponseBody)
    - void mapDifficulty(Recipe recipe, SearchRecipeResponseBody searchRecipeResponseBody)
    - void mapCategories(Recipe recipe, SearchRecipeResponseBody searchRecipeResponseBody)
    - void mapIngredients(Recipe recipe, SearchRecipeResponseBody searchRecipeResponseBody)
    - IngredientResponseBody mapToIngredientResponseBody(Ingredient ingredient)
    - void mapServings(Recipe recipe, SearchRecipeResponseBody searchRecipeResponseBody)
    - void mapCookingTime(Recipe recipe, SearchRecipeResponseBody searchRecipeResponseBody)
    - void mapInstructions(Recipe recipe, SearchRecipeResponseBody searchRecipeResponseBody)
}

DefaultRecipeToSearchRecipeResponseBodyMapper --> RecipeRepositoryV3
@enduml